@page "/Documents/Details/{id:int}"
@model Assignmet1_Presentation.Pages.Documents.DetailsModel
@{
    ViewData["Title"] = Model.ViewModel.OriginalName;
}

<section class="page-hero mb-4">
    <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-start gap-3">
        <div>
            <div class="hero-badge mb-3"><i data-lucide="file-text" class="icon-sm"></i> Chi tiết tài liệu</div>
            <h1 class="page-title mb-2">@Model.ViewModel.OriginalName</h1>
            <p class="page-subtitle mb-0">
                <span class="status-chip badge-soft me-2">@Model.ViewModel.FileType.ToUpper()</span>
                @if (Model.ViewModel.IsSlideDeck)
                {
                    <span class="status-chip badge-soft me-2">@Model.ViewModel.Chunks.Count trang slide</span>
                }
                @if (Model.ViewModel.ChapterNumber is not null)
                {
                    <span>Chương @Model.ViewModel.ChapterNumber: @Model.ViewModel.ChapterTitle</span>
                }
            </p>
        </div>
        <div class="d-flex flex-wrap gap-2">
            <a class="btn btn-outline-secondary" asp-page="/Documents/Index"><i data-lucide="arrow-left" class="icon-sm me-2"></i> Quay lại</a>
            @if (Model.ViewModel.CanReindex && Model.ViewModel.NeedsReindex)
            {
                <form asp-page-handler="Reindex" asp-route-id="@Model.ViewModel.Id" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-warning"><i data-lucide="refresh-cw" class="icon-sm me-2"></i> Lập chỉ mục lại</button>
                </form>
            }
            @if (Model.ViewModel.CanDelete)
            {
                <form asp-page-handler="Delete" asp-route-id="@Model.ViewModel.Id" method="post" class="d-inline" id="deleteDocForm">
                    @Html.AntiForgeryToken()
                    <button type="button" class="btn btn-outline-danger btn-delete-confirm" data-item-name="tài liệu này"><i data-lucide="trash-2" class="icon-sm me-2"></i> Xóa</button>
                </form>
            }
        </div>
    </div>
</section>

@if (TempData["Success"] is string success)
{
    <div class="alert alert-success">@success</div>
}
@if (TempData["Error"] is string error)
{
    <div class="alert alert-danger">@error</div>
}

<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="stat-card">
            <div class="stat-label"><i data-lucide="activity" class="icon-sm me-1"></i> Trạng thái</div>
            <div class="stat-value fs-6 @(Model.ViewModel.Status == "indexed" ? "text-success" : Model.ViewModel.Status == "failed" ? "text-danger" : "text-warning")">@Model.ViewModel.Status</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card">
            <div class="stat-label"><i data-lucide="layers" class="icon-sm me-1"></i> @(Model.ViewModel.IsSlideDeck ? "Trang slide" : "Chunks")</div>
            <div class="stat-value fs-6">@Model.ViewModel.Chunks.Count</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card">
            <div class="stat-label"><i data-lucide="user" class="icon-sm me-1"></i> Người tải lên</div>
            <div class="stat-value fs-6">@(Model.ViewModel.UploadedByName ?? "—")</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card">
            <div class="stat-label"><i data-lucide="clock" class="icon-sm me-1"></i> Ngày lập chỉ mục</div>
            <div class="stat-value fs-6 text-muted">@(Model.ViewModel.IndexedAt?.ToString("dd/MM/yyyy HH:mm") ?? "—")</div>
        </div>
    </div>
</div>

<div class="surface-card mb-4">
    <h4 class="mb-3 fw-semibold">@(Model.ViewModel.IsSlideDeck ? "Nội dung slide" : "Nội dung lập chỉ mục")</h4>

    @if (!Model.ViewModel.ChunkItems.Any())
    {
        <div class="alert alert-warning mb-0">
            <strong>Chưa có nội dung.</strong>
            @if (Model.ViewModel.CanReindex)
            {
                <span>Nhấn <strong>Lập chỉ mục lại</strong> hoặc tải lại file này để bắt đầu.</span>
            }
        </div>
    }
    else
    {
        @foreach (var item in Model.ViewModel.ChunkItems)
        {
            var chunk = item.Chunk;
            <div class="mini-panel mb-3">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    @if (item.IsSlide && item.SlideNumber.HasValue)
                    {
                        <div class="fw-semibold text-primary"><i data-lucide="image" class="icon-sm me-1"></i> Slide @item.SlideNumber</div>
                    }
                    else
                    {
                        <div class="fw-semibold text-primary"><i data-lucide="file-text" class="icon-sm me-1"></i> Chunk #@chunk.ChunkIndex</div>
                    }
                    <span class="status-chip badge-soft">@chunk.TokenCount tokens</span>
                </div>

                @if (item.ImageUrls.Any())
                {
                    <div class="row g-3 mb-3">
                        @foreach (var imageUrl in item.ImageUrls)
                        {
                            var isBrowserImage = imageUrl.EndsWith(".png", StringComparison.OrdinalIgnoreCase)
                                || imageUrl.EndsWith(".jpg", StringComparison.OrdinalIgnoreCase)
                                || imageUrl.EndsWith(".jpeg", StringComparison.OrdinalIgnoreCase)
                                || imageUrl.EndsWith(".gif", StringComparison.OrdinalIgnoreCase)
                                || imageUrl.EndsWith(".webp", StringComparison.OrdinalIgnoreCase);

                            @if (isBrowserImage)
                            {
                                <div class="col-md-6 col-lg-4">
                                    <div class="image-tile p-2 border rounded" style="background: rgba(255,255,255,0.02)">
                                        <img src="@imageUrl" alt="Slide @item.SlideNumber image" class="img-fluid rounded shadow-sm" />
                                    </div>
                                </div>
                            }
                        }
                    </div>
                }

                <div class="p-3 bg-dark bg-opacity-10 border rounded">
                    <pre class="mb-0 text-body" style="white-space: pre-wrap; font-family: inherit; font-size: 0.95rem;">@chunk.Content</pre>
                </div>
            </div>
        }
    }
</div>


